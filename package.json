{
  "name": "@mateusseiboth/ember-orm",
  "version": "0.1.7",
  "description": "Prisma-like ORM for Firebird. Schema, db pull, generated types, typed query API.",
  "license": "MIT",
  "author": "Mateus Seiboth",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateusseiboth/EmberORM.git"
  },
  "homepage": "https://github.com/mateusseiboth/EmberORM#readme",
  "bugs": {
    "url": "https://github.com/mateusseiboth/EmberORM/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js",
      "require": "./dist/editor.cjs"
    },
    "./studio": {
      "types": "./dist/studio/server.d.ts",
      "import": "./dist/studio/server.js",
      "require": "./dist/studio/server.cjs"
    }
  },
  "bin": {
    "ember": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && npm run build:studio",
    "build:lib": "tsup",
    "build:studio": "vite build --config studio-web/vite.config.ts",
    "dev": "tsup --watch",
    "dev:studio": "vite --config studio-web/vite.config.ts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ember": "tsx src/cli/bin.ts"
  },
  "keywords": [
    "firebird",
    "orm",
    "prisma",
    "sql",
    "typescript",
    "database"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-firebird": "^1.1.9"
  },
  "devDependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "codemirror": "^6.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
