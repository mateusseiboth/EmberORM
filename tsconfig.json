{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ember/schema": ["src/schema/index.ts"],
      "@ember/schema/*": ["src/schema/*"],
      "@ember/ast": ["src/ast/index.ts"],
      "@ember/ast/*": ["src/ast/*"],
      "@ember/driver": ["src/driver/index.ts"],
      "@ember/driver/*": ["src/driver/*"],
      "@ember/sql": ["src/sql/index.ts"],
      "@ember/sql/*": ["src/sql/*"],
      "@ember/query": ["src/query/index.ts"],
      "@ember/query/*": ["src/query/*"],
      "@ember/client": ["src/client/index.ts"],
      "@ember/client/*": ["src/client/*"],
      "@ember/introspect": ["src/introspect/index.ts"],
      "@ember/introspect/*": ["src/introspect/*"],
      "@ember/migrate": ["src/migrate/index.ts"],
      "@ember/migrate/*": ["src/migrate/*"],
      "@ember/studio": ["src/studio/index.ts"],
      "@ember/studio/*": ["src/studio/*"],
      "@ember/generator": ["src/generator/index.ts"],
      "@ember/generator/*": ["src/generator/*"],
      "@ember/errors": ["src/errors/index.ts"],
      "@ember/errors/*": ["src/errors/*"],
      "@ember/utils": ["src/utils/index.ts"],
      "@ember/utils/*": ["src/utils/*"],
      "@ember/types": ["src/types/index.ts"],
      "@ember/types/*": ["src/types/*"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist"]
}
