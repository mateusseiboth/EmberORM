{
  "name": "ember-orm-vscode",
  "displayName": "EmberORM",
  "description": "Language server for EmberORM `.ember` schema files: highlighting, diagnostics, formatting (with relation auto-completion), go-to-definition, references, rename, symbols, code actions and completion.",
  "version": "0.1.1",
  "license": "MIT",
  "icon": "media/icon.png",
  "publisher": "MateusSeiboth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mateusseiboth/EmberORM.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/mateusseiboth/EmberORM#readme",
  "bugs": {
    "url": "https://github.com/mateusseiboth/EmberORM/issues"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages", "Snippets", "Formatters"],
  "keywords": ["ember", "emberorm", "firebird", "orm", "prisma", "schema"],
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:ember"],
  "contributes": {
    "languages": [
      {
        "id": "ember",
        "aliases": ["Ember", "ember", "EmberORM"],
        "extensions": [".ember"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./media/icon.png",
          "dark": "./media/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ember",
        "scopeName": "source.ember",
        "path": "./syntaxes/ember.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ember",
        "path": "./snippets/ember.json"
      }
    ],
    "commands": [
      { "command": "ember.format", "title": "Ember: Format schema" },
      { "command": "ember.generate", "title": "Ember: Generate client" },
      { "command": "ember.dbPull", "title": "Ember: Pull database schema (db pull)" },
      { "command": "ember.validate", "title": "Ember: Validate schema" }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == ember",
          "command": "ember.format",
          "group": "1_modification"
        }
      ],
      "commandPalette": [
        { "command": "ember.format", "when": "resourceLangId == ember" }
      ]
    },
    "configuration": {
      "title": "EmberORM",
      "properties": {
        "ember.validateOnType": {
          "type": "boolean",
          "default": true,
          "description": "Validate the schema as you type (otherwise on save)."
        },
        "ember.cliPath": {
          "type": "string",
          "default": "npx ember",
          "description": "Command used to run the Ember CLI for generate/db pull."
        }
      }
    },
    "configurationDefaults": {
      "[ember]": {
        "editor.defaultFormatter": "MateusSeiboth.ember-orm-vscode",
        "editor.formatOnSave": true
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "tsup"
  },
  "dependencies": {
    "@mateusseiboth/ember-orm": "file:../..",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.82.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
